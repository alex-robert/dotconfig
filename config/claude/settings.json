{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(command wt:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "wt list statusline --format=claude-code"
  },
  "promptSuggestionEnabled": false,
  "enabledPlugins": {
    "worktrunk@worktrunk": true
  }
}
